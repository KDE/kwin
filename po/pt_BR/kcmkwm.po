#: ui/Focus.qml:22
#, kde-format
msgctxt "@label:listbox"
msgid "Window focus policy:"
msgstr "Política de foco da janela:"

#: ui/Focus.qml:46
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Click to focus"
msgstr "Clicar para obter o foco"

#: ui/Focus.qml:47
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window becomes focused when clicked."
msgstr "A janela recebe o foco ao ser clicada."

#: ui/Focus.qml:51
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus follows pointer"
msgstr "Foco segue o ponteiro"

#: ui/Focus.qml:52
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid ""
"As the pointer moves, windows under it become focused after a configurable "
"delay."
msgstr ""
"À medida que o ponteiro se move, as janelas sob ele recebem o foco após um "
"atraso configurável."

#: ui/Focus.qml:56
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus under pointer"
msgstr "Foco sob o ponteiro"

#: ui/Focus.qml:57
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window under pointer receives focus, even if the pointer has not moved."
msgstr ""
"A janela sob o ponteiro recebe o foco, mesmo que o ponteiro não tenha se "
"movido."

#: ui/Focus.qml:75
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Selecting <interface>Focus under pointer</interface> will prevent focus on "
"some windows appearing on screen. This can lead to assigning focus to "
"unwanted windows. Use with caution."
msgstr ""
"Selecionar <interface>Foco sob o ponteiro</interface> impedirá que o foco "
"seja aplicado a algumas janelas que aparecem na tela. Isso pode fazer com "
"que o foco seja atribuído a janelas indesejadas. Use com cautela."

#: ui/Focus.qml:81
#, kde-format
