#: ui/main.qml:29
#, kde-kuit-format
msgctxt "@info:usagetip"
msgid ""
"Legacy X11 apps with global shortcuts and other features accessed while "
"running in the background need to be able to listen for keystrokes all the "
"time.<nl/><nl/>If you use any of these apps, you can choose your preferred "
"balance of security and compatibility here."
msgstr ""
"יישומי X11 מיושנים עם קיצורי מקשים מקיפים לצד יכולות נוספות תוך ריצה ברקע "
"צריכים לקבל הרשאה להאזין להקשות כל הזמן.<nl/><nl/>במקרה של שימוש ביישומים "
"שכאלה, אפשר לבחור את האיזון המועדף עליך בין אבטחה ותאימות."

#: ui/main.qml:50
#, kde-format
msgctxt "@title:group"
msgid "Listening for keystrokes:"
msgstr "האזנה להקשות:"

#: ui/main.qml:57
#, kde-format
msgctxt "@option:radio Listening for keystrokes is prohibited"
msgid "Prohibited"
msgstr "אסורה"

#: ui/main.qml:73
#, kde-format
msgctxt "@info:usagetip"
msgid "Most secure; global shortcuts will not work in X11 apps"
msgstr "המאובטח ביותר, קיצורי מקשים מקיפים לא יעבדו ביישומי X11"

#: ui/main.qml:87
#, kde-format
msgctxt "@option:radio Listening for keystrokes is allowed for…"
msgid "Only the Meta, Control, Alt, and Shift keys"
msgstr "רק מקשי מטא, Ctrl,‏ Alt ו־Shift"

#: ui/main.qml:103
#, kde-format
msgctxt "@info:usagetip"
msgid ""
"High security; push-to-talk and other modifier-only global shortcuts will "
"work in X11 apps"
msgstr ""
"מאובטח מאוד, הקלדות קצובות וקיצורי מקשים מקיפים עם מקשי החלפה בלבד יעבדו "
"ביישומי X11"

#: ui/main.qml:117
#, kde-format
msgctxt "@option:radio Listening for keystrokes is allowed for…"
msgid ""
"As above, plus any key pressed while the Control, Alt, or Meta key is also "
"pressed"
msgstr "כמו לעיל, בתוספת כל מקש שהוא שנלחץ יחד עם Ctrl,‏ Alt או מטא"

#: ui/main.qml:133
#, kde-format
msgctxt "@info:usagetip"
msgid "Moderate security; all global shortcuts will work in X11 apps"
msgstr "אבטחה בינונית, כל קיצורי המקשים המקיפים יעבדו ביישומי X11"

#: ui/main.qml:147
#, kde-format
msgctxt "@option:radio Listening for keystrokes is always allowed"
msgid "Always allowed"
msgstr "מותר תמיד"

#: ui/main.qml:163
#, kde-format
msgctxt "@info:usagetip"
msgid ""
"Least secure; all X11 apps will be able to see any text you type into any "
"application"
msgstr ""
"הכי פחות מאובטח, כל יישומי X11 יוכלו לראות כל טקסט שמוקלד לכל יישום שהוא"

#: ui/main.qml:177
#, kde-format
msgctxt "@info:usagetip"
msgid ""
"Note that using this setting will reduce system security and permit "
"malicious software to steal passwords and spy on the text that you type. "
"Make sure you understand and accept this risk."
msgstr ""
"נא לשים לב ששימוש בהגדרה זו יערער את אבטחת המערכת וירשה לתוכנות זדוניות "
"לגנוב את הסיסמאות שלך ולרגל אחרי הטקסט המוקלד. נא לוודא שהכשלים האלו ברורים "
"לך ומוסכמים עליך."

#: ui/main.qml:193
#, kde-format
msgctxt "@title:group"
msgid "Listening for mouse buttons:"
msgstr "האזנה למקשי העכבר:"

#: ui/main.qml:199
#, kde-format
msgctxt "@option:radio Listening for mouse buttons is allowed"
msgid "Allowed"
msgstr "מורשה"

#: ui/main.qml:215
#, kde-format
msgctxt "@info:usagetip"
msgid ""
"Moderate security; global shortcuts involving mouse buttons will work in X11 "
"apps"
msgstr ""
"אבטחה בינונית, כל קיצורי המקשים המקיפים שקשורים לכפתורי עכבר יעבדו ביישומי "
"X11"

#: ui/main.qml:233
#, kde-format
msgctxt "@title:group"
msgid "Control of pointer and keyboard:"
msgstr "שליטה בסמן ובמקלדת:"

#: ui/main.qml:240
#, kde-format
msgctxt ""
"@option:check Allowed control of pointer and keyboard without asking for "
"permissions for allowed apps"
msgid "Allowed apps"
msgstr "יישומים מורשים"

#: ui/main.qml:246
#, kde-format
msgctxt "@action:button"
msgid "See Allowed Applications…"
msgstr "הצגת היישומים המורשים…"

#: ui/main.qml:259
#, kde-format
msgctxt "@info:usagetip"
msgid ""
"Moderate security; XWayland-using apps claiming to be something on this list "
"will be able to take control of the computer, because XWayland-using apps’ "
"identities can’t be verified"
msgstr ""
"אבטחה בינונית, יישומים שמשתמשים ב־XWayland שטוענים שהם אמורים להיות חלק "
"מהרשימה הזאת יוכלו לשלוט במחשב, כיוון שאי אפשר לאמת זהויות של יישומים "
"שמשתמשים ב־XWayland"

#: ui/main.qml:272
#, kde-format
msgctxt ""
"@option:radio Allow control of pointer and keyboard without asking for "
"permission"
msgid "Allow without asking for permission"
msgstr "לאפשר מבלי לבקש הרשאה"

#: ui/main.qml:283
#, kde-format
msgctxt "@info:usagetip"
msgid "Least secure; all X11 apps will be able to take control of the computer"
msgstr "הכי פחות מאובטח, כל יישומי X11 יוכלו לשלוט על המחשב"

#: ui/main.qml:295
#, kde-format
msgctxt ""
"@title:window title of the page opened by the 'See allowed applications' "
"button"
msgid "Applications allowed to control the pointer and keyboard"
msgstr "יישומים שמורשים לשלוט בסמן ובמקלדת"

#: ui/main.qml:315
#, kde-format
msgctxt "@info:tooltip %1 is the name of the app/binary"
msgid "Do not allow %1 to control the pointer and keyboard without asking"
msgstr "לא להרשות ליישום %1 לשלוט בסמן ובמקלדת מבלי לשאול"

#: ui/main.qml:329
#, kde-format
msgctxt "@info:usagetip"
msgid ""
"Note that using this setting will drastically reduce system security and "
"permit malicious software to take complete control of your pointer and "
"keyboard. Make sure you understand and accept this risk."
msgstr ""
"נא לשים לב ששימוש בהגדרה זו יערער את אבטחת המערכת וירשה לתוכנות זדוניות "
"להשתלט על הסמן והמקלדת שלך. נא לוודא שהכשלים האלו ברורים ומוסכמים עליך."

#~ msgctxt "@info"
#~ msgid "Changes will take effect the next time you log in."
#~ msgstr "השינויים יחולו לאחר כניסה מחדש למערכת."

#~ msgctxt "@action:button"
#~ msgid "Log Out Now"
#~ msgstr "לצאת עכשיו"

#~ msgid ""
#~ "Some legacy X11 apps require the ability to read keystrokes typed in "
#~ "other apps for certain features, such as handling global keyboard "
#~ "shortcuts. This is allowed by default. However other features may require "
#~ "the ability to read all keys, and this is disabled by default for "
#~ "security reasons. If you need to use such apps, you can choose your "
#~ "preferred balance of security and functionality here."
#~ msgstr ""
#~ "כל מיני יישומי X11 מיושנים דורשים את היכולת לקרוא לחיצות מקשים שהוקלו "
#~ "ביישומים אחרים לטובת מגוון מטרות, כגון טיפול בקיצור כלליים במקלדת. אפשרות "
#~ "זו מופעלת כברירת מחדל. עם זאת, יכולות אחרות יכולות לדרוש לקרוא את כל "
#~ "המקשים וזה מושבת כברירת מחדל מטעמי אבטחת מידע. אם כדי להשתמש ביישומים "
#~ "כאלה, האפשרות נחוצה לך, אפשר לבחור את האיזון המועדף עליך בין אבטחה לבין "
#~ "שימושיות."

#~ msgid "Allow legacy X11 apps to read keystrokes typed in all apps:"
#~ msgstr "לאפשר ליישומי X11 מיושנים לקרוא את הקשות המקלדת בכל היישומים:"

#~ msgid "Never"
#~ msgstr "אף פעם לא"

#~ msgid "Only non-character keys"
#~ msgstr "רק מקשים בלי תווים"

#~ msgid "All keys, but only while Meta, Ctrl, Alt, or Shift keys are pressed"
#~ msgstr "כל המקשים אבל רק אם נלחצים יחד עם המקשים מטא, Ctrl,‏ Alt או Shift"
