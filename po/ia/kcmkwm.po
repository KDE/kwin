#~ msgstr ""
#~ "<html><head/><body><p>Le politica de placiamento determina ubi un nove "
#~ "fenestra apparera in le scriptorio.</p><ul style=\"margin-top: 0px; "
#~ "margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: "
