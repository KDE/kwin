#: ui/Focus.qml:22
#, kde-format
msgctxt "@label:listbox"
msgid "Window focus policy:"
msgstr "Politica de foco de fenestra:"

#: ui/Focus.qml:46
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Click to focus"
msgstr "Pulsa pro focalisar"

#: ui/Focus.qml:47
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window becomes focused when clicked."
msgstr "Fenestra deveni focalisate quando cliccate."

#: ui/Focus.qml:51
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus follows pointer"
msgstr "Foco seque punctator"

#: ui/Focus.qml:52
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid ""
"As the pointer moves, windows under it become focused after a configurable "
"delay."
msgstr ""
"Como le punctator move, fenestra intra illo deveni focalisate post un "
"retardo configurabile."

#: ui/Focus.qml:56
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus under pointer"
msgstr "Foco intra punctator"

#: ui/Focus.qml:57
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window under pointer receives focus, even if the pointer has not moved."
msgstr ""
"Fenestra intra punctator recipe foco, anque si le punctator non ha movite."

#: ui/Focus.qml:75
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Selecting <interface>Focus under pointer</interface> will prevent focus on "
"some windows appearing on screen. This can lead to assigning focus to "
"unwanted windows. Use with caution."
msgstr ""
"Selectiona <interface>Foco intra le punctator</interface> impedira le foco "
"sur alcun  fenestras que appare sur le schermo. Isto pote ducer al "
"assignation del foco a  fenestras non desirate. Usa con precaution."

