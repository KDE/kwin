#: ui/Focus.qml:22
#, kde-format
msgctxt "@label:listbox"
msgid "Window focus policy:"
msgstr "窗口焦点策略："

#: ui/Focus.qml:46
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Click to focus"
msgstr "点击聚焦"

#: ui/Focus.qml:47
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window becomes focused when clicked."
msgstr "窗口在点击时取得焦点。"

#: ui/Focus.qml:51
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus follows pointer"
msgstr "焦点跟随指针移动"

#: ui/Focus.qml:52
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid ""
"As the pointer moves, windows under it become focused after a configurable "
"delay."
msgstr "随着指针移动，位于它下方的窗口在可配置的延迟后取得焦点。"

#: ui/Focus.qml:56
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus under pointer"
msgstr "焦点位于指针之下"

#: ui/Focus.qml:57
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window under pointer receives focus, even if the pointer has not moved."
msgstr "位于指针之下的窗口取得焦点，即使指针没有移动。"

#: ui/Focus.qml:75
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Selecting <interface>Focus under pointer</interface> will prevent focus on "
"some windows appearing on screen. This can lead to assigning focus to "
"unwanted windows. Use with caution."
msgstr ""
"选择 <interface>焦点位于指针之下</interface> 可能造成屏幕显示的某些窗口无法取"
"得焦点，系统会将焦点分配到错误的窗口。请谨慎使用。"

#: ui/Focus.qml:81
#, kde-format
msgctxt "@option:radio After closing a window, move focus to:"
msgid "Last focused window"
msgstr "上一个聚焦的窗口"

