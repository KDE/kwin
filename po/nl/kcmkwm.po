#: ui/Focus.qml:22
#, kde-format
msgctxt "@label:listbox"
msgid "Window focus policy:"
msgstr "Beleid voor activeren van venster:"

#: ui/Focus.qml:46
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Click to focus"
msgstr "Klikken voor focus"

#: ui/Focus.qml:47
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window becomes focused when clicked."
msgstr "Het venster krijgt focus wanneer erop wordt geklikt."

#: ui/Focus.qml:51
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus follows pointer"
msgstr "Focus volgt muisaanwijzer"

#: ui/Focus.qml:52
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid ""
"As the pointer moves, windows under it become focused after a configurable "
"delay."
msgstr ""
"Wanneer de muisaanwijzer beweegt, krijgen vensters eronder de focus na een "
"instelbare vertraging."

#: ui/Focus.qml:56
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus under pointer"
msgstr "Focus onder muisaanwijzer"

#: ui/Focus.qml:57
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window under pointer receives focus, even if the pointer has not moved."
msgstr ""
"Het venster onder de aanwijzer krijgt de focus, zelfs als de aanwijzer niet "
"is verplaatst."

#: ui/Focus.qml:75
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Selecting <interface>Focus under pointer</interface> will prevent focus on "
"some windows appearing on screen. This can lead to assigning focus to "
"unwanted windows. Use with caution."
msgstr ""
"Als u <interface>Focus onder de aanwijzer</interface> selecteert, wordt "
"voorkomen dat de focus op bepaalde vensters op het scherm verschijnt. Dit "
"kan ertoe leiden dat de focus aan ongewenste vensters wordt toegewezen. Wees "
"voorzichtig bij het gebruik hiervan."

