#: ui/Focus.qml:22
#, kde-format
msgctxt "@label:listbox"
msgid "Window focus policy:"
msgstr "Leihoen foku-gidalerroa:"

#: ui/Focus.qml:46
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Click to focus"
msgstr "Egin klik fokua emateko"

#: ui/Focus.qml:47
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window becomes focused when clicked."
msgstr "Leihoak fokua jasotzen du klik egiten zaionean."

#: ui/Focus.qml:51
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus follows pointer"
msgstr "Fokuak erakusleari jarraitzen dio"

#: ui/Focus.qml:52
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid ""
"As the pointer moves, windows under it become focused after a configurable "
"delay."
msgstr ""
"Erakuslea mugitzen den heinean, haren azpiko leihoak fokua jasoko dute "
"konfigura daitekeen atzerapen baten ondoren."

#: ui/Focus.qml:56
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus under pointer"
msgstr "Fokua erakuslearen azpian"

#: ui/Focus.qml:57
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window under pointer receives focus, even if the pointer has not moved."
msgstr ""
"Erakuslearen azpiko leihoak fokua jasotzen du, erakuslea mugitu ez bada ere."

#: ui/Focus.qml:75
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Selecting <interface>Focus under pointer</interface> will prevent focus on "
"some windows appearing on screen. This can lead to assigning focus to "
"unwanted windows. Use with caution."
msgstr ""
"<interface>Fokua erakuslearen azpian</interface> hautatuz gero, pantailan "
"agertzen diren leiho batzuei fokua ematea eragotziko da. Horren ondorioz, "
"fokua nahi ez diren leihoei eman dakieke. Kontuz erabili."

#: ui/Focus.qml:81
#, kde-format
msgctxt "@option:radio After closing a window, move focus to:"
msgid "Last focused window"
msgstr "Fokua jaso duen azken leihoa"

#: ui/Focus.qml:83
