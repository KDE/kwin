#: ui/Focus.qml:22
#, kde-format
msgctxt "@label:listbox"
msgid "Window focus policy:"
msgstr "Política de foco de ventanas:"

#: ui/Focus.qml:46
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Click to focus"
msgstr "Pulsar para enfocar"

#: ui/Focus.qml:47
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window becomes focused when clicked."
msgstr "La ventana obtiene el foco cuando se pulsa en ella."

#: ui/Focus.qml:51
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus follows pointer"
msgstr "El foco sigue al puntero"

#: ui/Focus.qml:52
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid ""
"As the pointer moves, windows under it become focused after a configurable "
"delay."
msgstr ""
"Cuando el puntero se mueve, las ventanas que quedan debajo obtienen el foco "
"tras una demora configurable."

#: ui/Focus.qml:56
#, kde-format
msgctxt "@item:inlistbox Window focus policy"
msgid "Focus under pointer"
msgstr "Foco bajo el puntero"

#: ui/Focus.qml:57
#, kde-format
msgctxt "@info:tooltip Window focus policy"
msgid "Window under pointer receives focus, even if the pointer has not moved."
msgstr ""
"Las ventanas que quedan debajo del puntero obtienen el foco, incluso cuando "
"el puntero no se ha movido."

#: ui/Focus.qml:75
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Selecting <interface>Focus under pointer</interface> will prevent focus on "
"some windows appearing on screen. This can lead to assigning focus to "
"unwanted windows. Use with caution."
msgstr ""
"Al seleccionar <interface>Foco bajo el puntero</interface> se impedirá que "
"algunas ventanas obtengan el foco en la pantalla. Esto puede provocar que se "
"asigne el foco a ventanas no deseadas. Úselo con precaución."

#: ui/Focus.qml:81
#, kde-format
msgctxt "@option:radio After closing a window, move focus to:"
msgid "Last focused window"
msgstr "Última ventana con el foco"

